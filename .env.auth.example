# =============================================================================
# NextAuth.js — copy these lines into .env.local
# =============================================================================
#
# 1. Generate NEXTAUTH_SECRET:
#      openssl rand -base64 32
#
# 2. Google OAuth (https://console.cloud.google.com/apis/credentials):
#    - Create OAuth 2.0 Client ID → Web application
#    - Authorized redirect URI:
#        http://localhost:3000/api/auth/callback/google
#      (production: https://your-domain.com/api/auth/callback/google)
#
# 3. Email/password accounts are stored via Upstash Redis when configured
#    (UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN in .env.local),
#    otherwise in-memory for local development only.
#
# =============================================================================

NEXTAUTH_SECRET=generate_a_random_string
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=get_from_google_console
GOOGLE_CLIENT_SECRET=get_from_google_console
