# =============================================================================
# NextAuth.js — copy these lines into .env.local
# =============================================================================
#
# 1. Generate NEXTAUTH_SECRET:
#      openssl rand -base64 32
#
# 2. Google OAuth (https://console.cloud.google.com/apis/credentials):
#    Authorized redirect URIs (SAMO ti dva):
#      http://localhost:3000/api/auth/callback/google
#      https://www.skybooplan.com/api/auth/callback/google
#    Odstrani vse *.vercel.app URI-je.
#
# 3. Email/password accounts are stored via Upstash Redis when configured
#    (UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN in .env.local),
#    otherwise in-memory for local development only.
#
# =============================================================================
# Vercel → Settings → Environment Variables
# =============================================================================
#
# PRODUCTION scope:
#   NEXTAUTH_URL=https://www.skybooplan.com   (BREZ končne /)
#   NEXTAUTH_SECRET=<openssl rand -base64 32>
#   GOOGLE_CLIENT_ID=...
#   GOOGLE_CLIENT_SECRET=...
#
# Iz PREVIEW in DEVELOPMENT scope-a ODSTRANI NEXTAUTH_URL
# (drugače preview deployi pokvarijo PKCE cookie).
#
# =============================================================================

NEXTAUTH_SECRET=generate_a_random_string
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=get_from_google_console
GOOGLE_CLIENT_SECRET=get_from_google_console
