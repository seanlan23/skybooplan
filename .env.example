# Duffel — iskanje letov (valuta = billing currency v Duffel dashboardu, nastavi EUR)
DUFFEL_ACCESS_TOKEN=
# Prikaz cen na karticah (Duffel ne podpira currency v offer requestu)
FLIGHTS_DISPLAY_CURRENCY=EUR
# Če Duffel vrne USD, pretvori v EUR (posodobi ročno ali prek tečaja)
FLIGHTS_USD_TO_EUR_RATE=0.92

# Flights Scraper Sky (RapidAPI) — opcijsko, samo rezerva za letališča
RAPIDAPI_KEY=
RAPIDAPI_FLIGHTS_HOST=flights-sky.p.rapidapi.com

# Travelpayouts (Drive skripta v layout.tsx; marker iz ?t=532915)
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=532915
# Program ID (p=) iz Tools → Create link → Skyscanner
NEXT_PUBLIC_TRAVELPAYOUTS_SKYSCANNER_P=
# ALI celotna vzorčna tp.media povezava:
# NEXT_PUBLIC_TRAVELPAYOUTS_SKYSCANNER_LINK=https://tp.media/r?marker=532915&p=1234&u=

# Booking.com — RapidAPI DataCrawler (booking-com15.p.rapidapi.com)
RAPIDAPI_KEY=
RAPIDAPI_BOOKING_HOST=booking-com15.p.rapidapi.com

# Booking.com / CJ Affiliate — aid v rezervacijskih URL-jih (privzeto 7969731 v src/config/booking.ts)
NEXT_PUBLIC_BOOKING_AID=7969731
BOOKING_AID=7969731

# OpenAI (AI načrt)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Upstash Redis (predpomnilnik hotelov)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox GL — zemljevid v AI planerju (NEXT_PUBLIC_ je obvezen za brskalnik)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Make.com — webhook ob generiranju AI načrta (tempo + želje + kontekst)
MAKE_WEBHOOK_URL=
# Make.com — PDF export gumb (Prenesi v PDF)
NEXT_PUBLIC_MAKE_PDF_WEBHOOK_URL=https://hook.eu1.make.com/uguqczf2ef6svceg84zaksco389milgc

# NextAuth.js — prijava (PDF / Google Docs)
# Glej tudi .env.auth.example za podrobna navodila
NEXTAUTH_SECRET=generate_a_random_string
# Produkcija: https://www.skybooplan.com (brez /). Google OAuth redirect_uri je fiksno nastavljen v auth.ts.
NEXTAUTH_URL=http://localhost:3000
# GOOGLE_OAUTH_REDIRECT_URI=https://www.skybooplan.com/api/auth/callback/google
# Google Cloud Console → Authorized redirect URIs (točen path!):
#   https://skybooplan.com/api/auth/callback/google
#   https://www.skybooplan.com/api/auth/callback/google
GOOGLE_CLIENT_ID=get_from_google_console
GOOGLE_CLIENT_SECRET=get_from_google_console
